{
  "name": "gym-management-system",
  "version": "1.0.0",
  "description": "Spor Salonu Yonetim ve Antrenman Takip Sistemi",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && npm install --prefix frontend",
    "build": "npm run build --prefix frontend"
  },
  "keywords": [
    "gym",
    "management",
    "sqlite",
    "express",
    "react"
  ],
  "author": "Rifat Arda Arslan",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "nodemailer": "^8.0.7",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  }
}
